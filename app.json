{
  "expo": {
    "name": "SleepSense-mobile-app",
    "slug": "sleepsense-mobile-app",
    "scheme": "sleepsense",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMotionUsageDescription": "SleepSense uses movement data to fine-tune your nightly sleep quality predictions."
      }
    },
    "android": {
      "package": "com.manushau.sleepsense",
      "permissions": [
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.PACKAGE_USAGE_STATS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "5bbc8198-9570-4966-a307-ba005f9ec039"
      }
    }
  }
}
